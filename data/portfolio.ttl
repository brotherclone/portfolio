    gw:summary "Academic instruction, curriculum design, studio teaching." .

gwi:domain_nonprofit a gw:Domain ;
    rdfs:label "Nonprofit / Public Interest" ;
    gw:summary "Mission-driven organizations, foundations, public-sector clients." .

gwi:domain_finance a gw:Domain ;
    rdfs:label "Financial Services" ;
    gw:summary "Investment management, banking, financial infrastructure." .

# ── ERAS ─────────────────────────────────────────────────────────────────────

gwi:era_earlyWeb a gw:Era ;
    rdfs:label "Early Web" ;
    gw:startYear 1997 ;
    gw:endYear 2000 ;
    gw:category "development" ;
    gw:nodeWeight 0.5 ;
