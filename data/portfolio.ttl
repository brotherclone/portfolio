gwi:era_agentic a gw:Era ;
    rdfs:label "Agentic Architecture" ;
    gw:startYear 2021 ;
    gw:endYear 0 ;
    gw:category "development" ;
    gw:nodeWeight 0.95 ;
    gw:summary "Oracle, ontology, MCP, AGUI. Building the infrastructure layer for human-AI interfaces." .

# ── CONCEPTS ─────────────────────────────────────────────────────────────────

gwi:concept_experienceIntegration a gw:Concept ;
    rdfs:label "Experience Integration" ;
    gw:category "design" ;
    gw:nodeWeight 0.95 ;
    gw:ledTo gwi:concept_contentModeling, gwi:concept_physicalDigital ;
    gw:summary "The practice of designing coherent experiences across physical, digital, temporal, and organizational boundaries. The 28-year thread." .

gwi:concept_contentModeling a gw:Concept ;
    rdfs:label "Content Modeling" ;
    gw:category "strategy" ;
    gw:nodeWeight 0.7 ;
    gw:informedBy gwi:concept_experienceIntegration ;
    gw:ledTo gwi:concept_ontologyDesign ;
    gw:summary "Structured content as design material — taxonomies, controlled vocabularies, content graphs. The bridge from IA to ontology work." .

gwi:concept_ontologyDesign a gw:Concept ;
    rdfs:label "Ontology Design" ;
    gw:category "development" ;
    gw:nodeWeight 0.85 ;
    gw:informedBy gwi:concept_experienceIntegration, gwi:concept_contentModeling ;
    gw:ledTo gwi:concept_agenticArchitecture ;
    gw:evidencedBy gwi:artifact_portfolio_site ;
    gw:summary "Formal modelling of domain knowledge: entities, relationships, constraints, inference rules. OWL, SPARQL, LinkML, RDF." .

gwi:concept_agenticArchitecture a gw:Concept ;
    rdfs:label "Agentic Architecture" ;
    gw:category "development" ;
    gw:nodeWeight 0.9 ;
    gw:informedBy gwi:concept_ontologyDesign, gwi:concept_physicalDigital ;
    gw:evidencedBy gwi:artifact_portfolio_site ;
    gw:summary "Designing systems where AI agents are first-class participants — MCP, AGUI, LangChain, entity resolution, graph-grounded reasoning." .

gwi:concept_physicalDigital a gw:Concept ;
    rdfs:label "Physical-Digital Integration" ;
    gw:category "design" ;
    gw:nodeWeight 0.8 ;
    gw:informedBy gwi:concept_experienceIntegration ;
    gw:ledTo gwi:concept_spatialComputing ;
    gw:summary "Designing for bodies and spaces, not just screens. Arduino, Unity, IoT, physical computing, LEGO. Preceded the mainstream IoT moment." .

gwi:concept_spatialComputing a gw:Concept ;
    rdfs:label "Spatial Computing" ;
    gw:category "development" ;
    gw:nodeWeight 0.55 ;
    gw:summary "Emerging territory: AR/VR/XR, 3D interfaces, AI-physical interaction. Natural extension of 27 years of 3D and physical-digital work." .

gwi:concept_creativeProduction a gw:Concept ;
    rdfs:label "Creative Production" ;
    gw:category "artifact" ;
    gw:nodeWeight 0.75 ;
    gw:evidencedBy gwi:artifact_earthly_frames ;
    gw:summary "Traditional animation, 3D modelling, audio production, film. The art practice running in parallel to the tech practice for 28 years." .

